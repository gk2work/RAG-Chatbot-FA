data/embeddings/
data/faiss_index/
*.faiss
*.pkl

# Uploaded files
app/static/uploads/*
!app/static/uploads/.gitkeep

# Database files
*.sqlite3
*.db

# Temporary files
*.tmp
*.temp
temp/
tmp/

